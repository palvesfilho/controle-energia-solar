generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("INVESTOR") // ADMIN | GESTOR | FINANCEIRO | POS_VENDA | GESTOR_OBRA | INVESTOR | CONSUMER
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  investor Investor?
  uploads  Upload[]

  @@map("users")
}

model Investor {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  phone              String?
  document           String? // Legacy - usar cpf/cnpj
  cpf                String?
  dataNascimento     DateTime? @map("data_nascimento")
  endereco           String?
  numero             String?
  complemento        String?
  cep                String?
  bairro             String?
  cidade             String?
  nomeEmpresa        String?   @map("nome_empresa")
  cnpj               String?
  enderecoEmpresa    String?   @map("endereco_empresa")
  numeroEmpresa      String?   @map("numero_empresa")
  complementoEmpresa String?   @map("complemento_empresa")
  cepEmpresa         String?   @map("cep_empresa")
  bairroEmpresa      String?   @map("bairro_empresa")
  cidadeEmpresa      String?   @map("cidade_empresa")
  chavePix           String?   @map("chave_pix")
  // Emails adicionais (sócios, financeiro etc.). JSON-encoded array de strings.
  additionalEmails   String?   @map("additional_emails")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plants      InvestorPlant[]
  reports     MonthlyReport[]
  payables    InvestorPayable[]
  settlements InvestorSettlement[]
  debits      InvestorDebit[]

  @@map("investors")
}

model Plant {
  id                 String  @id @default(cuid())
  name               String
  location           String?
  potenciaModulos    Float?  @map("potencia_modulos")
  potenciaInversor   Float?  @map("potencia_inversor")
  geracaoMediaMensal Float?  @map("geracao_media_mensal")
  enquadramento      String?
  unidadeConsumidora String? @map("unidade_consumidora")
  concessionaria     String?
  formatoLeitura     String? @map("formato_leitura")
  regraInstalacao    String? @map("regra_instalacao") // USINA_DEDICADA | USINA_CONSUMO_PROPRIO | USINA_CONSUMO_DESCONTADO
  active             Boolean @default(true)

  // Dados do Inversor
  inversorMarca  String? @map("inversor_marca")
  inversorModelo String? @map("inversor_modelo")

  // Monitoramento
  monitoramentoPlataforma String? @map("monitoramento_plataforma")
  monitoramentoLogin      String? @map("monitoramento_login")
  monitoramentoSenha      String? @map("monitoramento_senha")
  monitoramentoUrl        String? @map("monitoramento_url")

  // Novos campos da planilha
  fonte                  String? // SOLAR, EOLICA, etc
  numeroUsina            String?   @map("numero_usina")
  potenciaInstalada      Float?    @map("potencia_instalada")
  grupo                  String? // A, B, etc
  cpfCnpj                String?   @map("cpf_cnpj")
  distribuidora          String? // RGE, CPFL_PAULISTA, CPFL_PIRATININGA
  acesso                 String? // Ok, Pendente, etc
  statusContrato         String?   @map("status_contrato")
  // Data em que o contrato com o investidor foi assinado (não necessariamente
  // quando a usina começou a injetar). Usada como início da janela de faturas
  // a descontar no primeiro relatório do investidor.
  dataAssinaturaContrato DateTime? @map("data_assinatura_contrato")
  loginDistribuidora     String?   @map("login_distribuidora")
  senhaDistribuidora     String?   @map("senha_distribuidora")
  codigoCliente          String?   @map("codigo_cliente") // Número de instalação/código do cliente no portal da distribuidora

  // Dia do mês em que o investidor desta usina recebe o repasse. Default 20 pra
  // todas; gestor pode ajustar por usina na tela de cadastro. Usado pela Agenda
  // da Semana pra gerar a task PAGAR_INVESTIDOR e EMITIR_RELATORIO_MENSAL
  // (esta última = pagamento - 3 dias).
  diaPagamentoInvestidor Int @default(20) @map("dia_pagamento_investidor")

  // Quem paga a fatura de energia da usina pra distribuidora:
  // - GESTORA: a gestora paga e depois cobra/desconta dos investidores (fluxo padrão)
  // - INVESTIDORES: cada investidor paga direto, gestora só acompanha pra controle
  // Afeta soma "a pagar" da agenda e badge na Gestão Financeira.
  pagadorFaturaEnergia String @default("GESTORA") @map("pagador_fatura_energia")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  investors         InvestorPlant[]
  consumers         ConsumerPlant[]
  reports           MonthlyReport[]
  monthlyData       PlantMonthly[]
  consumerData      ConsumerMonthly[]
  consumerBills     ConsumerBill[]
  consumerUnits     ConsumerUnit[]
  billings          PlantBilling[]
  cpflCredential    CpflCredential?
  // 1:N — uma Plant pode ter várias usinas monitoradas (inversores) injetando
  // na mesma fatura da concessionária.
  monitoringClients BrasilSolarClient[] @relation("PlantMonitoring")
  rateioVersions    RateioVersion[]
  documents         PlantDocument[]
  investorPayables  InvestorPayable[]

  @@map("plants")
}

model PlantDocument {
  id           String   @id @default(cuid())
  plantId      String   @map("plant_id")
  type         String // CNH_RG | PROCURACAO | CONTRATO_SOCIAL | CARTAO_CNPJ
  url          String
  fileName     String   @map("file_name")
  size         Int?
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, type])
  @@index([plantId])
  @@map("plant_documents")
}

model PlantBilling {
  id      String @id @default(cuid())
  plantId String @map("plant_id")

  // Período de referência
  ano Int
  mes Int

  // Status do faturamento
  // PENDENTE → AGUARDANDO_DOCUMENTOS → AGUARDANDO_PAGAMENTO → PAGO
  status String @default("PENDENTE")

  // Valores
  valorTotal  Float?  @map("valor_total")
  observacoes String?

  // Relatório gerado pelo sistema (PDF / planilha)
  relatorioGeradoUrl String?   @map("relatorio_gerado_url")
  relatorioGeradoAt  DateTime? @map("relatorio_gerado_at")
  relatorioGeradoBy  String?   @map("relatorio_gerado_by")

  // Documentos enviados pelo dono da usina
  notaFiscalUrl    String?   @map("nota_fiscal_url")
  notaFiscalAt     DateTime? @map("nota_fiscal_at")
  reciboTerraUrl   String?   @map("recibo_terra_url")
  reciboTerraAt    DateTime? @map("recibo_terra_at")
  reciboAluguelUrl String?   @map("recibo_aluguel_url")
  reciboAluguelAt  DateTime? @map("recibo_aluguel_at")

  // Comprovante de pagamento (financeiro)
  comprovantePagamentoUrl String?   @map("comprovante_pagamento_url")
  comprovantePagamentoAt  DateTime? @map("comprovante_pagamento_at")
  comprovantePagamentoBy  String?   @map("comprovante_pagamento_by")

  // Encerramento do mes — setado quando o comprovante eh anexado OU
  // quando o operador formaliza "sem pagamento no mes" (semPagamentoMotivo).
  // Bloqueia todas as edicoes do mes (relatorio, payables, faturas, docs)
  // para roles != ADMIN. Apenas ADMIN reabre (limpa encerradoEm).
  encerradoEm        DateTime? @map("encerrado_em")
  encerradoPorUserId String?   @map("encerrado_por_user_id")

  // Motivo do encerramento "sem pagamento" (saldo negativo, sem geracao,
  // pausa contratual, outro). Quando preenchido, indica que o mes foi
  // encerrado sem comprovante de pagamento. Limpo no /reabrir.
  semPagamentoMotivo String? @map("sem_pagamento_motivo")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, ano, mes])
  @@index([ano, mes])
  @@map("plant_billings")
}

model InvestorPlant {
  id                 String @id @default(cuid())
  investorId         String @map("investor_id")
  plantId            String @map("plant_id")
  sharePercent       Float? @map("share_percent")
  valorKwhContrato   Float? @map("valor_kwh_contrato") // R$/kWh pago ao investidor
  gestaoFixaContrato Float? @map("gestao_fixa_contrato") // R$ gestao fixa mensal

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  plant    Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([investorId, plantId])
  @@map("investor_plants")
}

model MonthlyReport {
  id              String  @id @default(cuid())
  plantId         String  @map("plant_id")
  investorId      String  @map("investor_id")
  ano             Int
  mes             Int
  numeroRelatorio String? @map("numero_relatorio")
  status          String  @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED

  // Resultado Energetico
  injecaoPeriodo     Float? @map("injecao_periodo")
  creditosAnteriores Float? @map("creditos_anteriores")
  creditosUtilizados Float? @map("creditos_utilizados")
  consumoInstantaneo Float? @map("consumo_instantaneo")
  autoConsumoUsina   Float? @map("auto_consumo_usina")
  creditosAtuais     Float? @map("creditos_atuais")
  creditosVencer     Float? @map("creditos_vencer")

  // Resultado Financeiro
  creditosUtilizadosFin Float? @map("creditos_utilizados_fin")
  valorKwhContrato      Float? @map("valor_kwh_contrato")
  valorBrutoGerador     Float? @map("valor_bruto_gerador")
  gestaoMensalFixa      Float? @map("gestao_mensal_fixa")
  taxaMinimaConc        Float? @map("taxa_minima_conc")
  inadimplencia         Float? @map("inadimplencia")
  multasOutros          Float? @map("multas_outros")
  remuneracaoPeriodo    Float? @map("remuneracao_periodo")

  // Observacoes
  observacoes String?

  // AI Analysis
  aiAnalysis         String? @map("ai_analysis")
  aiValidationStatus String? @map("ai_validation_status")

  // Snapshot completo dos dados consumidos pelo PDF — congelado no publish.
  // Estrutura segue InvestorReportData. Quando presente + status=PUBLISHED,
  // o PDF eh re-renderizado deste snapshot (imutavel mesmo se a base mudar).
  // Quando null, o gerador recalcula da base normalmente (DRAFT).
  snapshotJson String? @map("snapshot_json")

  // Metadata
  uploadId          String?   @map("upload_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  publishedAt       DateTime? @map("published_at")
  publishedByUserId String?   @map("published_by_user_id")

  plant    Plant    @relation(fields: [plantId], references: [id])
  investor Investor @relation(fields: [investorId], references: [id])
  upload   Upload?  @relation(fields: [uploadId], references: [id])

  @@unique([plantId, investorId, ano, mes])
  @@index([investorId, ano, mes])
  @@map("monthly_reports")
}

model PlantMonthly {
  id      String @id @default(cuid())
  plantId String @map("plant_id")
  ano     Int
  mes     Int

  geracaoTotal    Float?  @map("geracao_total") // kWh total gerado pela usina
  injecaoTotal    Float?  @map("injecao_total") // kWh injetado na rede
  autoConsumo     Float?  @map("auto_consumo") // kWh autoconsumo
  disponibilidade Float?  @map("disponibilidade") // % de disponibilidade
  observacoes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plant Plant @relation(fields: [plantId], references: [id])

  @@unique([plantId, ano, mes])
  @@map("plant_monthly")
}

model ConsumerMonthly {
  id         String @id @default(cuid())
  consumerId String @map("consumer_id")
  plantId    String @map("plant_id")
  ano        Int
  mes        Int

  consumoTotal       Float?  @map("consumo_total") // kWh consumo total do consumidor
  creditosRecebidos  Float?  @map("creditos_recebidos") // kWh creditos alocados
  creditosUtilizados Float?  @map("creditos_utilizados") // kWh creditos efetivamente usados
  saldoCreditos      Float?  @map("saldo_creditos") // kWh saldo de creditos
  economiaGerada     Float?  @map("economia_gerada") // R$ economia no periodo
  observacoes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consumer Consumer @relation(fields: [consumerId], references: [id])
  plant    Plant    @relation(fields: [plantId], references: [id])

  @@unique([consumerId, plantId, ano, mes])
  @@map("consumer_monthly")
}

model Consumer {
  id                 String  @id @default(cuid())
  name               String
  email              String?
  phone              String?
  document           String? // CPF ou CNPJ
  endereco           String?
  unidadeConsumidora String? @map("unidade_consumidora")
  active             Boolean @default(true)

  // Novos campos da planilha
  cpfCnpj           String?   @map("cpf_cnpj")
  loginPortal       String?   @map("login_portal")
  emailsRecebimento String?   @map("emails_recebimento") // separados por ;
  dataCadastro      DateTime? @map("data_cadastro")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plants        ConsumerPlant[]
  monthly       ConsumerMonthly[]
  consumerUnits ConsumerUnit[]

  @@map("consumers")
}

model ConsumerUnit {
  id         String  @id @default(cuid())
  consumerId String? @map("consumer_id")
  plantId    String? @map("plant_id")

  // Identificação
  nome     String
  codigoUc String  @unique @map("codigo_uc")
  cpfCnpj  String? @map("cpf_cnpj")

  // Distribuidora e classificação
  distribuidora String?
  grupo         String?
  subGrupo      String? @map("sub_grupo")
  modalidade    String? // AUTOCONSUMO_REMOTO, GERACAO_COMPARTILHADA, etc

  // Consumo
  consumoMedio Float? @map("consumo_medio")

  // Endereço
  cep         String?
  logradouro  String?
  complemento String?
  numero      String?
  cidade      String?

  // Comercial
  consultor         String?
  comissao          String?
  metodoPagamento   String? @map("metodo_pagamento")
  regraRemuneracao  String? @map("regra_remuneracao")
  percentCompensado Float?  @map("percent_compensado")
  percentBandeira   Float?  @map("percent_bandeira")
  regraVencimento   String? @map("regra_vencimento")
  valorVencimento   Float?  @map("valor_vencimento")

  // Contrato
  statusContrato      String? @map("status_contrato")
  vigenciaCompensacao String? @map("vigencia_compensacao")

  // Acesso à distribuidora
  loginDistribuidora String? @map("login_distribuidora")
  senhaDistribuidora String? @map("senha_distribuidora")

  // UC tem geração própria (placas solares no medidor). Lei 14.300: distribuidora
  // compensa primeiro a injeção própria; o restante consome créditos da usina do
  // rateio. Auto-marcado como true quando uma fatura chega com
  // energiaInjetadaMedidorKwh > 0.
  temGeracaoPropria Boolean @default(false) @map("tem_geracao_propria")

  // Grupo A — cadastro contratual da UC (coexiste com `modalidade` que é GD, não tarifária)
  modalidadeTarifaria      String? @map("modalidade_tarifaria") // "Verde"|"Azul"|"Convencional"|"Branca"
  tensaoNominalContratadaV Float?  @map("tensao_nominal_contratada_v")
  demandaContratadaKw      Float?  @map("demanda_contratada_kw") // Verde/Conv: única; Azul: FPonta
  demandaContratadaPontaKw Float?  @map("demanda_contratada_ponta_kw") // só Azul
  geracaoContratadaKw      Float?  @map("geracao_contratada_kw") // GD Grupo A (kW de geração contratada)

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consumer         Consumer?             @relation(fields: [consumerId], references: [id], onDelete: SetNull)
  plant            Plant?                @relation(fields: [plantId], references: [id], onDelete: SetNull)
  billings         ConsumerUnitBilling[]
  bills            ConsumerBill[]
  cpflCredential   CpflCredential?
  rateioItems      RateioItem[]
  investorPayables InvestorPayable[]

  @@index([consumerId])
  @@index([plantId])
  @@map("consumer_units")
}

model ConsumerUnitBilling {
  id             String @id @default(cuid())
  consumerUnitId String @map("consumer_unit_id")

  // Período de referência (mês da fatura de energia)
  ano Int
  mes Int

  // Valores apurados
  valorFatura     Float? @map("valor_fatura") // R$ total da fatura de energia
  valorCompensado Float? @map("valor_compensado") // R$ compensado pela usina
  valorEconomia   Float? @map("valor_economia") // R$ economia gerada
  valorCobranca   Float? @map("valor_cobranca") // R$ a cobrar do consumidor

  dataVencimento DateTime? @map("data_vencimento")
  observacoes    String?

  // Status: PENDENTE → ENVIADO_ASAAS → PARCIALMENTE_PAGO → PAGO | ATRASADO | CANCELADO
  // PARCIALMENTE_PAGO: cobrança parcelada com pelo menos 1 parcela paga, mas ainda há parcelas em aberto.
  status String @default("PENDENTE")

  // Parcelamento (uso esporádico): JSON array de até 10 parcelas, criadas como
  // cobranças Asaas independentes. null = cobrança única (fluxo padrão).
  // Estrutura: [{ dueDate: "YYYY-MM-DD", valor: number, asaasChargeId, asaasInvoiceUrl, asaasStatus, pagoEm: ISO|null }]
  installments String? @map("installments")

  // Fatura de energia anexada (PDF distribuidora)
  faturaUrl String?   @map("fatura_url")
  faturaAt  DateTime? @map("fatura_at")

  // Preferências de envio escolhidas pelo operador (persistidas mesmo sem disparar)
  notificarEmail    Boolean @default(true) @map("notificar_email")
  notificarWhatsapp Boolean @default(false) @map("notificar_whatsapp")

  // Integração Asaas
  asaasChargeId   String?   @map("asaas_charge_id")
  asaasInvoiceUrl String?   @map("asaas_invoice_url")
  asaasStatus     String?   @map("asaas_status")
  asaasSyncedAt   DateTime? @map("asaas_synced_at")

  // Pagamento confirmado
  pagoEm         DateTime? @map("pago_em")
  // Canal do pagamento — preenchido em pagamento manual (PIX direto, dinheiro, etc.)
  // ou marcado como BOLETO_ASAAS pelo webhook quando vem via Asaas.
  // Valores: PIX_DIRETO | DINHEIRO | TRANSFERENCIA | OUTRO | BOLETO_ASAAS
  formaPagamento String?   @map("forma_pagamento")
  pagamentoNota  String?   @map("pagamento_nota")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consumerUnit     ConsumerUnit      @relation(fields: [consumerUnitId], references: [id], onDelete: Cascade)
  investorPayables InvestorPayable[]

  @@unique([consumerUnitId, ano, mes])
  @@index([ano, mes])
  @@map("consumer_unit_billings")
}

model ConsumerPlant {
  id              String @id @default(cuid())
  consumerId      String @map("consumer_id")
  plantId         String @map("plant_id")
  cotaPercent     Float? @map("cota_percent") // % dos creditos alocados ao consumidor
  descontoPercent Float? @map("desconto_percent") // % de desconto sobre a tarifa

  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  plant    Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([consumerId, plantId])
  @@map("consumer_plants")
}

model ConsumerBill {
  id             String  @id @default(cuid())
  consumerUnitId String? @map("consumer_unit_id")
  plantId        String? @map("plant_id")

  // Referencia da fatura
  mesReferencia Int     @map("mes_referencia")
  anoReferencia Int     @map("ano_referencia")
  instalacao    String? // Numero da instalacao na concessionaria

  // Valores da fatura
  valorTotal   Float?    @map("valor_total")
  vencimento   DateTime?
  contaPaga    Boolean   @default(false) @map("conta_paga")
  codigoBarras String?   @map("codigo_barras")
  pixCopiaCola String?   @map("pix_copia_cola")

  // Pagamento da fatura para a distribuidora (registrado pelo financeiro
  // via tela "Pagar Faturas"). Independe do contaPaga (que vem do parser).
  pagoEm                  DateTime? @map("pago_em")
  bancoPagamento          String?   @map("banco_pagamento") // BANRISUL | C6_BANK | ASAAS
  comprovantePagamentoUrl String?   @map("comprovante_pagamento_url")
  comprovantePagamentoAt  DateTime? @map("comprovante_pagamento_at")
  // Origem do registro: "BACKUP LUMI" para importações via CSV;
  // nome do usuário quando feito pela tela do sistema.
  origemPagamento         String?   @map("origem_pagamento")

  // Dados de consumo
  consumoKwh          Float?    @map("consumo_kwh")
  leituraAnterior     Float?    @map("leitura_anterior")
  leituraAtual        Float?    @map("leitura_atual")
  diasFaturamento     Int?      @map("dias_faturamento")
  proximaLeitura      DateTime? @map("proxima_leitura") // Próxima leitura — referência pra agendar sync
  // Janela do ciclo de leitura (não coincide com mês calendário). Usado pra validar inversor x medidor.
  dataLeituraAnterior DateTime? @map("data_leitura_anterior")
  dataLeituraAtual    DateTime? @map("data_leitura_atual")

  // Consumo faturado (mes atual) - TE e TUSD com quantidade e valor
  consumoTeKwh     Float? @map("consumo_te_kwh")
  consumoTeValor   Float? @map("consumo_te_valor")
  consumoTusdKwh   Float? @map("consumo_tusd_kwh")
  consumoTusdValor Float? @map("consumo_tusd_valor")

  // Creditos de energia (GD)
  energiaInjetada   Float? @map("energia_injetada")
  energiaCompensada Float? @map("energia_compensada")
  saldoCreditos     Float? @map("saldo_creditos")

  // Energia ativa injetada oUC (compensada no mes, total agregado)
  injetadaOucTeKwh     Float?  @map("injetada_ouc_te_kwh")
  injetadaOucTeValor   Float?  @map("injetada_ouc_te_valor")
  injetadaOucTusdKwh   Float?  @map("injetada_ouc_tusd_kwh")
  injetadaOucTusdValor Float?  @map("injetada_ouc_tusd_valor")
  // Detalhamento por mes de origem: [{ mesOrigem, teKwh, teValor, tusdKwh, tusdValor }]
  injetadaDetalhes     String? @map("injetada_detalhes")

  // Historico de consumo (13 meses) vindos da fatura: [{ mesAno, consumoKwh, dias }]
  historicoConsumo String? @map("historico_consumo")

  // Saldo de energia (GD) detalhado
  saldoInstalacaoKwh     Float? @map("saldo_instalacao_kwh")
  saldoExpirarProxMesKwh Float? @map("saldo_expirar_prox_mes_kwh")
  participacaoGeracaoPct Float? @map("participacao_geracao_pct")

  // Validação fatura × inversor: persiste resultado da última checagem feita
  // pelo operador no botão "Validar" da listagem de faturamentos. Sem isso,
  // o estado vivia só no React e exigia re-clicar a cada visita à tela.
  validacaoStatus  String?   @map("validacao_status") // OK | ALERTA | SEM_FATURA | SEM_INVERSOR
  validacaoDiffPct Float?    @map("validacao_diff_pct")
  validacaoEm      DateTime? @map("validacao_em")

  // Leitura física da injeção (fatura de usina) — grandeza "Energia Injetada" do medidor.
  // kWh injetado = (leituraAtual - leituraAnterior) * constante. Valida contra inversor.
  energiaInjetadaMedidorKwh Float? @map("energia_injetada_medidor_kwh")
  leituraInjetadaAnterior   Float? @map("leitura_injetada_anterior")
  leituraInjetadaAtual      Float? @map("leitura_injetada_atual")
  constanteMedidorInjetada  Float? @map("constante_medidor_injetada")

  // Custo de Disponibilidade (cobrança mínima B3 trifásico = 100 kWh). Separado do consumo real.
  custoDispTusdKwh   Float? @map("custo_disp_tusd_kwh")
  custoDispTusdValor Float? @map("custo_disp_tusd_valor")
  custoDispTeKwh     Float? @map("custo_disp_te_kwh")
  custoDispTeValor   Float? @map("custo_disp_te_valor")

  // ===== Grupo A — tarifa binômia + posto horário (P/FP) =====
  // Todos opcionais. Grupo B preenche null em tudo. Validado contra UC 4003710227 (OBA Verde-A4).

  // Consumo por posto
  consumoPontaKwh           Float? @map("consumo_ponta_kwh")
  consumoForaPontaKwh       Float? @map("consumo_fora_ponta_kwh")
  consumoTePontaKwh         Float? @map("consumo_te_ponta_kwh")
  consumoTePontaValor       Float? @map("consumo_te_ponta_valor")
  consumoTeForaPontaKwh     Float? @map("consumo_te_fora_ponta_kwh")
  consumoTeForaPontaValor   Float? @map("consumo_te_fora_ponta_valor")
  consumoTusdPontaKwh       Float? @map("consumo_tusd_ponta_kwh")
  consumoTusdPontaValor     Float? @map("consumo_tusd_ponta_valor")
  consumoTusdForaPontaKwh   Float? @map("consumo_tusd_fora_ponta_kwh")
  consumoTusdForaPontaValor Float? @map("consumo_tusd_fora_ponta_valor")

  // Tarifas por posto
  tarifaTePonta       Float? @map("tarifa_te_ponta")
  tarifaTeForaPonta   Float? @map("tarifa_te_fora_ponta")
  tarifaTusdPonta     Float? @map("tarifa_tusd_ponta")
  tarifaTusdForaPonta Float? @map("tarifa_tusd_fora_ponta")

  // Bandeira por posto
  bandeiraValorPonta            Float? @map("bandeira_valor_ponta")
  bandeiraValorForaPonta        Float? @map("bandeira_valor_fora_ponta")
  bandeiraCreditoPontaValor     Float? @map("bandeira_credito_ponta_valor")
  bandeiraCreditoForaPontaValor Float? @map("bandeira_credito_fora_ponta_valor")

  // Demanda (medida + ultrapassagem)
  demandaMedidaKw           Float? @map("demanda_medida_kw")
  demandaMedidaPontaKw      Float? @map("demanda_medida_ponta_kw") // só Azul
  demandaTusdValor          Float? @map("demanda_tusd_valor")
  tarifaDemanda             Float? @map("tarifa_demanda")
  demandaUltrapassagemKw    Float? @map("demanda_ultrapassagem_kw")
  demandaUltrapassagemValor Float? @map("demanda_ultrapassagem_valor")

  // TUSD-G (uso da rede pela geração — UC com mini/microGD em Grupo A)
  tusdGeracaoKw     Float? @map("tusd_geracao_kw")
  tusdGeracaoValor  Float? @map("tusd_geracao_valor")
  tarifaTusdGeracao Float? @map("tarifa_tusd_geracao")

  // Compensação Lei 14.300 por posto (TUSD+TE somados)
  injetadaPontaKwh       Float? @map("injetada_ponta_kwh")
  injetadaPontaValor     Float? @map("injetada_ponta_valor") // negativo (crédito)
  injetadaForaPontaKwh   Float? @map("injetada_fora_ponta_kwh")
  injetadaForaPontaValor Float? @map("injetada_fora_ponta_valor") // negativo (crédito)

  // Saldo de créditos por posto (Grupo A)
  saldoPontaKwh     Float? @map("saldo_ponta_kwh")
  saldoForaPontaKwh Float? @map("saldo_fora_ponta_kwh")

  // Reativo excedente
  reativoExcedentePontaKvar      Float? @map("reativo_excedente_ponta_kvar")
  reativoExcedentePontaValor     Float? @map("reativo_excedente_ponta_valor")
  reativoExcedenteForaPontaKvar  Float? @map("reativo_excedente_fora_ponta_kvar")
  reativoExcedenteForaPontaValor Float? @map("reativo_excedente_fora_ponta_valor")

  // Leituras múltiplas (8 grandezas: Ativa P/FP, Demanda P/FP, Reativa P/FP, Injetada P/FP)
  // JSON pra não inflar mais o schema. Estrutura: GrupoALeituraMedidor[] de fatura-pdf-parser-grupo-a.ts
  leiturasMedidorJson String? @map("leituras_medidor_json")

  // Tarifas
  tarifaTE          Float?  @map("tarifa_te") // Tarifa Energia (ANEEL)
  tarifaTUSD        Float?  @map("tarifa_tusd") // Tarifa Uso Sistema Distribuicao
  bandeiraTarifaria String? @map("bandeira_tarifaria")
  bandeiraValor     Float?  @map("bandeira_valor") // Soma R$ de todas as linhas de bandeira da fatura

  // Consumo instantâneo: energia gerada pela usina e consumida na hora, sem
  // passar pela rede (não compensada). Só faz sentido para UC geradora em
  // USINA_CONSUMO_DESCONTADO — entra no cálculo de cobrança. Derivado de
  // `geracaoInversorKwh - energiaInjetadaMedidorKwh` quando ambos existem.
  consumoInstantaneoKwh Float? @map("consumo_instantaneo_kwh")

  // Geração total do inversor no período da fatura (kWh). Usada para derivar
  // consumo instantâneo em UC geradora DESCONTADO. Pode vir de:
  //  - AUTO: coleta via API do inversor (Fronius/Huawei/SolarEdge/Sungrow)
  //  - MANUAL: preenchido quando o inversor fica offline / sem dados
  geracaoInversorKwh    Float?  @map("geracao_inversor_kwh")
  geracaoInversorOrigem String? @map("geracao_inversor_origem") // "AUTO" | "MANUAL"

  // Impostos
  icms   Float?
  pis    Float?
  cofins Float?

  // Encargos e ajustes
  jurosMora            Float? @map("juros_mora")
  multaAtraso          Float? @map("multa_atraso")
  atualizacaoMonetaria Float? @map("atualizacao_monetaria")
  iluminacaoPublicaCip Float? @map("iluminacao_publica_cip")
  ajusteSaldoCredito   Float? @map("ajuste_saldo_credito")

  // Metadados da sincronizacao
  fonteConsulta String?  @map("fonte_consulta") // "INFOSIMPLES" | "MANUAL" | "CPFL_PORTAL"
  pdfUrl        String?  @map("pdf_url")
  rawJson       String?  @map("raw_json") // Resposta completa da API
  syncedAt      DateTime @default(now()) @map("synced_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consumerUnit           ConsumerUnit?     @relation(fields: [consumerUnitId], references: [id], onDelete: Cascade)
  plant                  Plant?            @relation(fields: [plantId], references: [id])
  // Payables criados a partir desta fatura (lado do consumidor — quem teve a compensação)
  investorPayables       InvestorPayable[] @relation("PayablesFromConsumerBill")
  // Payables originados pela leitura desta fatura (lado da usina — quem injetou os créditos
  // que foram dispachados nessa janela). É a chave do "mês de geração" usado como
  // competência do relatório do investidor.
  payablesOriginatedHere InvestorPayable[] @relation("PayablesOriginatedByPlantBill")

  @@unique([consumerUnitId, anoReferencia, mesReferencia])
  @@index([consumerUnitId, anoReferencia])
  @@index([plantId, anoReferencia])
  @@map("consumer_bills")
}

model CpflCredential {
  id             String  @id @default(cuid())
  consumerUnitId String? @unique @map("consumer_unit_id")
  plantId        String? @unique @map("plant_id")

  emailCpfl     String @map("email_cpfl") // Login no portal CPFL
  senhaCpfl     String @map("senha_cpfl") // Senha no portal CPFL (criptografada)
  instalacao    String // Numero da instalacao
  distribuidora String @default("RGE") // RGE | CPFL_PAULISTA | CPFL_PIRATININGA

  ultimaSync DateTime? @map("ultima_sync")
  statusSync String?   @map("status_sync") // "SUCCESS" | "ERROR" | "PENDING"
  erroSync   String?   @map("erro_sync")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consumerUnit ConsumerUnit? @relation(fields: [consumerUnitId], references: [id], onDelete: Cascade)
  plant        Plant?        @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("cpfl_credentials")
}

model Upload {
  id              String    @id @default(cuid())
  fileName        String    @map("file_name")
  fileSize        Int       @map("file_size")
  filePath        String    @map("file_path")
  mimeType        String    @map("mime_type")
  uploadedById    String    @map("uploaded_by_id")
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error")
  rawData         String?   @map("raw_data")

  createdAt DateTime @default(now()) @map("created_at")

  uploadedBy User            @relation(fields: [uploadedById], references: [id])
  reports    MonthlyReport[]

  @@map("uploads")
}

// ============================================================
// BRASIL SOLAR - Monitoramento de Clientes
// ============================================================

model BrasilSolarClient {
  id String @id @default(cuid())

  // Dados do cliente
  nome      String
  cpfCnpj   String? @map("cpf_cnpj")
  email     String?
  telefone  String?
  endereco  String?
  cidade    String?
  uf        String?
  bairro    String?
  cep       String?
  latitude  Float?
  longitude Float?

  // Dados da instalacao
  potenciaInstalada  Float?    @map("potencia_instalada") // kWp
  dataInstalacao     DateTime? @map("data_instalacao")
  modulosMarca       String?   @map("modulos_marca")
  modulosModelo      String?   @map("modulos_modelo")
  modulosQuantidade  Int?      @map("modulos_quantidade")
  inversorMarca      String?   @map("inversor_marca")
  inversorModelo     String?   @map("inversor_modelo")
  inversorQuantidade Int?      @map("inversor_quantidade")
  inversorPotencia   Float?    @map("inversor_potencia") // kW

  // Plataforma de monitoramento
  plataformaMonitoramento String? @map("plataforma_monitoramento") // GROWATT, SOLIS, FRONIUS, HUAWEI, CANADIAN, ABB, DEYE, HOYMILES, SUNGROW, SOFAR, SOLAREDGE
  monitoramentoLogin      String? @map("monitoramento_login")
  monitoramentoSenha      String? @map("monitoramento_senha")
  monitoramentoUrl        String? @map("monitoramento_url")
  monitoramentoPlantId    String? @map("monitoramento_plant_id")

  // Concessionaria
  concessionaria String?
  codigoUc       String? @map("codigo_uc")

  // Contrato
  statusContrato String?   @map("status_contrato") // ATIVO, SUSPENSO, CANCELADO, GARANTIA
  dataContrato   DateTime? @map("data_contrato")
  consultor      String?
  garantiaAte    DateTime? @map("garantia_ate")

  // Financeiro
  investimento Float? // R$ valor total do investimento na usina

  // Geracao esperada (para calcular performance ratio)
  geracaoMediaEsperada Float? @map("geracao_media_esperada") // kWh/mes esperado
  geracaoAnualEsperada Float? @map("geracao_anual_esperada") // kWh/ano esperado
  geracaoContrato      Float? @map("geracao_contrato") // kWh conforme contrato

  // Status atual (desnormalizado para queries rapidas em 2700+ registros)
  statusMonitoramento String    @default("SEM_DADOS") @map("status_monitoramento") // ONLINE, OFFLINE, ALERTA, SEM_DADOS
  ultimaGeracao       Float?    @map("ultima_geracao") // kWh ultimo dia
  ultimaLeitura       DateTime? @map("ultima_leitura")
  geracaoMesAtual     Float?    @map("geracao_mes_atual") // kWh acumulado mes
  performanceRatio    Float?    @map("performance_ratio") // % real vs esperado

  // Métricas instantâneas coletadas pelo sync/metrics (Fase 2.1)
  tensaoRede          Float?    @map("tensao_rede") // V - tensão AC medida (fase mais alta quando trifásico)
  tensaoNominalRede   Float?    @map("tensao_nominal_rede") // V - nominal (127/220); inferida pela medida quando null
  frequenciaRede      Float?    @map("frequencia_rede") // Hz - frequência AC medida
  temperaturaInversor Float?    @map("temperatura_inversor") // °C - temperatura interna do inversor
  ultimaMetricaEm     DateTime? @map("ultima_metrica_em") // timestamp da última coleta de métricas instantâneas

  // Observacoes internas
  observacoesInternas String? @map("observacoes_internas")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacoes
  monitoringLogs  MonitoringLog[]
  alerts          MonitoringAlert[]
  inverterSamples InverterSample[]
  monitoringPlans BrasilSolarMonitoringPlan[]

  // Link opcional com dados existentes
  consumerId String? @map("consumer_id")
  // plantId: quando preenchido, associa esta usina monitorada à Plant (Gestor
  // de Créditos) que recebe sua geração. 1:N (uma Plant pode agregar várias
  // usinas monitoradas injetando na mesma fatura da concessionária).
  plantId    String? @map("plant_id")
  plant      Plant?  @relation("PlantMonitoring", fields: [plantId], references: [id], onDelete: SetNull)

  // Proprietario (dono da usina)
  proprietarioId String?                  @map("proprietario_id")
  proprietario   BrasilSolarProprietario? @relation(fields: [proprietarioId], references: [id], onDelete: SetNull)

  @@index([statusMonitoramento])
  @@index([cidade])
  @@index([uf])
  @@index([plataformaMonitoramento])
  @@index([statusContrato])
  @@index([nome])
  @@index([proprietarioId])
  @@index([plantId])
  @@map("brasil_solar_clients")
}

// Histórico de planos de monitoramento pago contratados por usina.
// Renovação cria um novo registro — não edita o anterior. Plano vigente é
// derivado: registro com dataInicio <= hoje <= dataFim. Sem registro = sem plano.
model BrasilSolarMonitoringPlan {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  dataInicio  DateTime @map("data_inicio")
  dataFim     DateTime @map("data_fim")
  valorMensal Float?   @map("valor_mensal")
  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client BrasilSolarClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, dataFim])
  @@map("brasil_solar_monitoring_plans")
}

// Pares chave/valor pra parâmetros editáveis em /admin/personalizacoes.
// Genérico de propósito — uma key por parâmetro (ex.:
// "relatorio.reajusteTarifaAnual", "relatorio.depreciacaoModuloAnual").
// Valor sempre serializado como string; helpers convertem pra número/json.
model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// Sample do inversor a cada 30 min, coletado via Sungrow
// (getDevicePointMinuteDataList). Cobre 5h–21h BRT (32 amostras/dia).
// p1Wh = energia diária acumulada (zera 00h UTC); p2Wh = lifetime (não zera).
model InverterSample {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  psKey     String   @map("ps_key") // identificador do inversor no Sungrow
  timeStamp DateTime @map("time_stamp") // UTC
  p1Wh      Float?   @map("p1_wh") // energia diária acumulada (Wh) — zera 00h UTC
  p2Wh      Float?   @map("p2_wh") // energia lifetime acumulada (Wh)
  // Potência AC ativa em Watts no instante (soma p14+p24 do payload Sungrow).
  // Sinal limpo de geração — vira null quando inversor desliga.
  pAcW      Float?   @map("p_ac_w")
  createdAt DateTime @default(now()) @map("created_at")

  client BrasilSolarClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([psKey, timeStamp])
  @@index([clientId, timeStamp])
  @@map("inverter_samples")
}

model BrasilSolarProprietario {
  id String @id @default(cuid())

  nome     String
  cpfCnpj  String? @map("cpf_cnpj")
  email    String?
  telefone String?
  endereco String?
  cidade   String?
  uf       String?

  // Dados técnicos extraídos do Anexo F (CPFL/RGE). Ficam no proprietário
  // porque a usina em si é sincronizada por API (Fronius/SolarEdge/...) e
  // depois vinculada manualmente — mas os dados do PDF precisam persistir
  // e ficar visíveis aqui.
  latitude           Float?
  longitude          Float?
  codigoUc           String? @map("codigo_uc")
  concessionaria     String?
  potenciaInstalada  Float?  @map("potencia_instalada")
  modulosMarca       String? @map("modulos_marca")
  modulosModelo      String? @map("modulos_modelo")
  modulosQuantidade  Int?    @map("modulos_quantidade")
  inversorMarca      String? @map("inversor_marca")
  inversorModelo     String? @map("inversor_modelo")
  inversorQuantidade Int?    @map("inversor_quantidade")
  inversorPotencia   Float?  @map("inversor_potencia")
  numeroFases        String? @map("numero_fases")
  tipoAtendimento    String? @map("tipo_atendimento")

  // Dados de gestão do contrato/obra. Coletados na criação do proprietário
  // (obrigatórios via API; nullable no banco apenas para tolerar registros
  // anteriores à migração).
  // tipoTelhado: FIBROCIMENTO | CERAMICO | LAJE | CARPORT | USINA_DE_SOLO |
  //              CALHETAO_FIBROCIMENTO | CALHETAO_METALICO | MISTO
  // tipoTelhadoOutro: descrição livre quando tipoTelhado = MISTO
  tipoTelhado       String?   @map("tipo_telhado")
  tipoTelhadoOutro  String?   @map("tipo_telhado_outro")
  dataPagamento     DateTime? @map("data_pagamento")
  prazoContratoDias Int?      @map("prazo_contrato_dias")

  observacoes String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Um proprietario pode ter varias usinas (plantas)
  plantas BrasilSolarClient[]

  @@index([nome])
  @@index([cpfCnpj])
  @@index([codigoUc])
  @@map("brasil_solar_proprietarios")
}

model MonitoringLog {
  id       String @id @default(cuid())
  clientId String @map("client_id")

  data            DateTime // Data da leitura
  geracaoDiaria   Float    @map("geracao_diaria") // kWh gerado no dia
  geracaoEsperada Float?   @map("geracao_esperada") // kWh esperado no dia
  picoMaximo      Float?   @map("pico_maximo") // kW pico do dia
  horasSol        Float?   @map("horas_sol") // Horas de sol equivalente
  irradiacao      Float? // kWh/m2 irradiacao solar
  temperatura     Float? // Temperatura media inversores

  createdAt DateTime @default(now()) @map("created_at")

  client BrasilSolarClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, data])
  @@index([data])
  @@index([clientId, data])
  @@map("monitoring_logs")
}

model MonitoringAlert {
  id       String @id @default(cuid())
  clientId String @map("client_id")

  // Tipo e severidade
  tipo       String // OFFLINE, BAIXA_GERACAO, ERRO_INVERSOR, CONSUMO_ELEVADO, FATURA_IRREGULAR, MANUTENCAO
  severidade String  @default("MEDIA") // BAIXA, MEDIA, ALTA, CRITICA
  titulo     String
  descricao  String?

  // Status do alerta
  status String @default("ABERTO") // ABERTO, EM_ANDAMENTO, RESOLVIDO, IGNORADO

  // Resolucao
  resolvidoPor        String?   @map("resolvido_por")
  resolvidoEm         DateTime? @map("resolvido_em")
  observacaoResolucao String?   @map("observacao_resolucao")

  // Notificacoes
  notificadoCliente    Boolean @default(false) @map("notificado_cliente")
  notificadoEngenharia Boolean @default(false) @map("notificado_engenharia")

  // Ação requerida sugerida pro time de engenharia/pós-venda.
  // Valores: IR_EM_CAMPO, VERIFICAR_REMOTO, CONTATAR_CLIENTE, CONTATAR_CONCESSIONARIA, MONITORAR.
  // Default aplicado a partir do tipo na criação (ver lib/alertas-usinas.ts:getAcaoRequeridaDefault).
  acaoRequerida String? @map("acao_requerida")

  // Código de erro reportado pelo inversor (ex.: Fronius 103, SolarEdge 0x3A).
  // Operador digita manualmente; sistema busca em InverterErrorCode pra mostrar
  // título + ações sugeridas. Fabricante é inferido a partir do client.inversorMarca
  // ou client.plataformaMonitoramento na hora do lookup.
  codigoErroFabricante String? @map("codigo_erro_fabricante")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client BrasilSolarClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tipo])
  @@index([severidade])
  @@index([acaoRequerida])
  @@index([clientId, status])
  @@index([createdAt])
  @@map("monitoring_alerts")
}

// Configuração global de thresholds para detecção de alertas em usinas.
// Um registro por tipo (BAIXA_GERACAO, OFFLINE, TENSAO_FORA). Editável em
// /admin/personalizacoes/alertas-usinas. Lida pela rota sync/alerts.
model AlertaThreshold {
  id String @id @default(cuid())

  // BAIXA_GERACAO | OFFLINE | TENSAO_FORA
  tipo    String  @unique
  enabled Boolean @default(true)

  // Para alertas percentuais (BAIXA_GERACAO usa PR%, TENSAO_FORA usa desvio%).
  // Convenção: thresholdCritico sempre é o limite mais severo.
  thresholdCritico Float? @map("threshold_critico")
  thresholdMedio   Float? @map("threshold_medio")
  thresholdBaixo   Float? @map("threshold_baixo")

  // Para alertas binários (OFFLINE): BAIXA | MEDIA | ALTA | CRITICA
  severidadeDefault String? @map("severidade_default")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("alerta_thresholds")
}

// Base de conhecimento de códigos de erro por fabricante de inversor.
// Cada código tem N ações sugeridas em ordem (ver InverterErrorAction).
// Editável em /admin/personalizacoes/codigos-erro-inversor.
model InverterErrorCode {
  id         String  @id @default(cuid())
  fabricante String // FRONIUS | SOLAREDGE | SUNGROW | HUAWEI
  codigo     String // ex.: "103", "0x3A", "STATE_103"
  titulo     String
  descricao  String?

  // Severidade sugerida (BAIXA | MEDIA | ALTA | CRITICA). Operador pode sobrescrever no alerta.
  severidadeSugerida String? @map("severidade_sugerida")

  acoes InverterErrorAction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([fabricante, codigo])
  @@index([fabricante])
  @@map("inverter_error_codes")
}

model InverterErrorAction {
  id          String @id @default(cuid())
  errorCodeId String @map("error_code_id")
  ordem       Int
  descricao   String

  // Etiqueta de classificação: IR_EM_CAMPO | VERIFICAR_REMOTO | CONTATAR_CLIENTE | CONTATAR_CONCESSIONARIA | MONITORAR.
  acaoRequerida String? @map("acao_requerida")

  errorCode InverterErrorCode @relation(fields: [errorCodeId], references: [id], onDelete: Cascade)

  @@unique([errorCodeId, ordem])
  @@index([errorCodeId])
  @@map("inverter_error_actions")
}

// ============================================================
// CRONOGRAMA DE OBRAS - Gantt com dependências
// ============================================================

model Obra {
  id          String  @id @default(cuid())
  nome        String
  descricao   String?
  responsavel String?
  cliente     String?
  local       String?

  // Status geral da obra
  // PLANEJAMENTO | EM_EXECUCAO | PAUSADA | CONCLUIDA | CANCELADA
  status String @default("PLANEJAMENTO")

  // Aprovação do gestor antes de entrar no cronograma
  // PENDENTE | ACEITA | RECUSADA
  aprovacao String @default("PENDENTE")

  // Datas consolidadas (derivadas das tarefas, mas armazenadas para query rápida)
  dataInicioPrevista DateTime? @map("data_inicio_prevista")
  dataFimPrevista    DateTime? @map("data_fim_prevista")
  dataInicioReal     DateTime? @map("data_inicio_real")
  dataFimReal        DateTime? @map("data_fim_real")

  // Progresso 0-100 (média ponderada das tarefas)
  progresso Float @default(0)

  // Vínculo opcional com Plant (usina) ou BrasilSolarClient
  plantId                   String? @map("plant_id")
  brasilSolarClientId       String? @map("brasil_solar_client_id")
  brasilSolarProprietarioId String? @map("brasil_solar_proprietario_id")

  // Equipe de execução designada (opcional). Validação de sobreposição
  // de datas é feita por equipe — duas obras da mesma equipe não podem
  // ter intervalos que se toquem.
  equipeId String? @map("equipe_id")

  // BAIXA | MEDIA | ALTA | URGENTE
  prioridade String @default("MEDIA")

  observacoes String?

  // Marcos de geração de PDFs (ficam preenchidos a cada geração —
  // o gestao-obra usa estes para pintar os ícones de verde)
  documentoPdfGeradoEm   DateTime? @map("documento_pdf_gerado_em")
  conferenciaPdfGeradoEm DateTime? @map("conferencia_pdf_gerado_em")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tarefas       ObraTarefa[]
  listaMaterial ObraListaMaterial?
  equipe        EquipeExecucao?    @relation(fields: [equipeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([aprovacao])
  @@index([dataInicioPrevista])
  @@index([plantId])
  @@index([brasilSolarProprietarioId])
  @@index([equipeId])
  @@map("obras")
}

// Lista de Materiais editável por obra. Pré-preenchida pelo template fixo
// (Rede Brasil Solar) na primeira abertura; persiste edições do usuário e
// mantém referência ao último PDF gerado.
model ObraListaMaterial {
  id                  String  @id @default(cuid())
  obraId              String  @unique @map("obra_id")
  responsavel         String?
  numeroSerieInversor String? @map("numero_serie_inversor")
  observacoes         String?

  // Último PDF gerado a partir desta lista
  pdfRelativePath String?   @map("pdf_relative_path")
  pdfUploadId     String?   @map("pdf_upload_id")
  pdfGeradoEm     DateTime? @map("pdf_gerado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  obra  Obra                    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  itens ObraListaMaterialItem[]

  @@map("obra_lista_materiais")
}

model ObraListaMaterialItem {
  id      String @id @default(cuid())
  listaId String @map("lista_id")

  // Agrupamento no PDF/UI: INVERSOR | ELETRICO | ESTRUTURA | FIXACAO | AVISOS
  categoria     String
  descricao     String
  especificacao String?
  quantidade    String
  ordem         Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lista ObraListaMaterial @relation(fields: [listaId], references: [id], onDelete: Cascade)

  @@index([listaId, ordem])
  @@map("obra_lista_material_itens")
}

model ObraTarefa {
  id     String @id @default(cuid())
  obraId String @map("obra_id")

  nome      String
  descricao String?
  ordem     Int     @default(0)

  // Planejamento
  dataInicioPlan DateTime @map("data_inicio_plan")
  dataFimPlan    DateTime @map("data_fim_plan")
  duracaoDias    Int      @map("duracao_dias") // duração em dias úteis

  // Execução real
  dataInicioReal DateTime? @map("data_inicio_real")
  dataFimReal    DateTime? @map("data_fim_real")

  // Progresso 0-100
  progresso Float @default(0)

  // Status da tarefa
  // NAO_INICIADA | EM_EXECUCAO | PAUSADA | CONCLUIDA | ATRASADA
  status String @default("NAO_INICIADA")

  responsavel String?
  cor         String? // cor da barra no Gantt (hex)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  obra         Obra                @relation(fields: [obraId], references: [id], onDelete: Cascade)
  dependencias TarefaDependencia[] @relation("TarefaSucessora") // esta tarefa depende de quais
  dependentes  TarefaDependencia[] @relation("TarefaPredecessora") // quem depende desta tarefa

  @@index([obraId])
  @@index([obraId, ordem])
  @@map("obra_tarefas")
}

model TarefaDependencia {
  id          String @id @default(cuid())
  tarefaId    String @map("tarefa_id") // tarefa sucessora (depende de)
  dependeDeId String @map("depende_de_id") // tarefa predecessora

  // Tipo de dependência:
  // FS = Finish-to-Start (padrão): predecessora precisa terminar antes da sucessora começar
  // SS = Start-to-Start: ambas começam juntas
  // FF = Finish-to-Finish: ambas terminam juntas
  // SF = Start-to-Finish: sucessora termina quando predecessora começa
  tipo String @default("FS")

  // Lag em dias (pode ser negativo para antecipar)
  lagDias Int @default(0) @map("lag_dias")

  createdAt DateTime @default(now()) @map("created_at")

  tarefa    ObraTarefa @relation("TarefaSucessora", fields: [tarefaId], references: [id], onDelete: Cascade)
  dependeDe ObraTarefa @relation("TarefaPredecessora", fields: [dependeDeId], references: [id], onDelete: Cascade)

  @@unique([tarefaId, dependeDeId])
  @@index([tarefaId])
  @@index([dependeDeId])
  @@map("tarefa_dependencias")
}

// Tabela de materiais padrão por potência de inversor.
// Usada na aba Personalizações > Obras para centralizar o dimensionamento
// de disjuntor, cabo, CD, DPS, barramento, canaleta, caixa e placas
// conforme a planilha "LISTA DE MATERIAIS PARA OBRAS".
// Equipe de execução (instaladores) — lista em Personalizações >
// Equipes. Usada para selecionar responsável ao programar uma obra.
model EquipeExecucao {
  id                  String  @id @default(cuid())
  nome                String  @unique
  telefoneResponsavel String? @map("telefone_responsavel")
  cor                 String? // hex color (#RRGGBB) usada no cronograma
  active              Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  obras Obra[]

  @@index([active])
  @@map("equipes_execucao")
}

model ObraMaterialPadrao {
  id                String  @id @default(cuid())
  potenciaW         Int     @unique @map("potencia_w")
  disjuntorA        Int?    @map("disjuntor_a")
  caboMm2           Float?  @map("cabo_mm2")
  cdPosicoes        String? @map("cd_posicoes")
  dpsQtd            Int?    @map("dps_qtd")
  barramento        String?
  canaleta          String?
  caixaPassagem     String? @map("caixa_passagem")
  placaRge          Int?    @map("placa_rge")
  placaPisarModulos Int?    @map("placa_pisar_modulos")
  placaGerador      Int?    @map("placa_gerador")
  observacoes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([potenciaW])
  @@map("obra_materiais_padrao")
}

// ============================================================
// EMAILS DAS CONCESSIONÁRIAS — cadastro do destino (setor de GD)
// e do remetente autorizado, usado no envio de rateio por email.
// ============================================================
model DistribuidoraEmail {
  id              String  @id @default(cuid())
  distribuidora   String  @unique // ex: RGE, CPFL_PAULISTA, CEEE_EQUATORIAL
  emailDestino    String  @map("email_destino") // setor de GD da concessionária
  emailRemetente  String  @map("email_remetente") // de qual conta o sistema dispara
  emailCc         String? @map("email_cc") // múltiplos separados por ;
  nomeResponsavel String? @map("nome_responsavel") // responsável nosso pelo envio
  observacoes     String?
  active          Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("distribuidora_emails")
}

// ============================================================
// RATEIO DE CRÉDITOS — % por UC por usina, com versionamento
// ============================================================
// Uma Plant tem 1 rateio VIGENTE por vez. Ao propor um novo, ele nasce
// PENDENTE_ACEITE e o anterior continua VIGENTE até a concessionária
// aceitar (daí o antigo vira SUBSTITUIDO e o novo vira VIGENTE). Se for
// rejeitado, vira REJEITADO e o anterior permanece valendo.
model RateioVersion {
  id               String    @id @default(cuid())
  plantId          String    @map("plant_id")
  status           String    @default("PENDENTE_ACEITE") // VIGENTE | PENDENTE_ACEITE | REJEITADO | SUBSTITUIDO
  observacao       String?
  // Primeiro mês de referência em que este rateio passa a valer (compara com ConsumerBill.mesReferencia/anoReferencia).
  // Permite criar rateios retroativos e agendar entrada em vigor no futuro.
  vigenteAPartirDe DateTime  @default(now()) @map("vigente_a_partir_de")
  criadoEm         DateTime  @default(now()) @map("criado_em")
  enviadoEm        DateTime? @map("enviado_em") // enviado à concessionária
  aceitoEm         DateTime? @map("aceito_em")
  rejeitadoEm      DateTime? @map("rejeitado_em")
  substituidoEm    DateTime? @map("substituido_em")
  criadoPorUserId  String?   @map("criado_por_user_id")

  plant            Plant             @relation(fields: [plantId], references: [id], onDelete: Cascade)
  items            RateioItem[]
  investorPayables InvestorPayable[]

  @@index([plantId, status])
  @@map("rateio_versions")
}

model RateioItem {
  id             String @id @default(cuid())
  versionId      String @map("version_id")
  consumerUnitId String @map("consumer_unit_id")
  percentual     Float // 0..100 — soma dos itens da versão deve ser 100

  version      RateioVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  consumerUnit ConsumerUnit  @relation(fields: [consumerUnitId], references: [id], onDelete: Cascade)

  @@unique([versionId, consumerUnitId])
  @@index([versionId])
  @@index([consumerUnitId])
  @@map("rateio_items")
}

// Parcela a pagar ao investidor por (UC do rateio × mês de referência).
// Fluxo: AGUARDANDO_COMPENSACAO → AGUARDANDO_PAGAMENTO → DISPONIVEL → PAGO.
// Criada sob demanda quando ConsumerBill chega com energiaCompensada > 0.
// Base + ajuste preservam auditoria de intervenções manuais no fechamento.
model InvestorPayable {
  id String @id @default(cuid())

  investorId     String @map("investor_id")
  plantId        String @map("plant_id")
  consumerUnitId String @map("consumer_unit_id")
  mesReferencia  Int    @map("mes_referencia")
  anoReferencia  Int    @map("ano_referencia")

  // 0 = cobrança única ou parcela 1 de N. Para parcelamento, gera N payables
  // (parcelaIndex 0..N-1), cada um com valorBruto/Liquido = total/N. Cada parcela
  // paga libera independentemente seu próprio payable.
  parcelaIndex Int @default(0) @map("parcela_index")

  // Snapshot do contrato/rateio no momento da criação
  sharePercent     Float   @map("share_percent")
  valorKwhContrato Float   @map("valor_kwh_contrato")
  rateioVersionId  String? @map("rateio_version_id")

  // Valores (base = calculado, ajuste = intervenção manual, líquido = final)
  kwhCompensadoBase       Float   @map("kwh_compensado_base")
  kwhCompensadoAjuste     Float   @default(0) @map("kwh_compensado_ajuste")
  valorBruto              Float   @map("valor_bruto")
  valorAjuste             Float   @default(0) @map("valor_ajuste")
  // Soma das aplicações de InvestorDebit nesta payable. Reduz o valorLiquido.
  // Mantido como coluna persistida (não calculado) pra simplificar queries/settlements.
  valorAbatidoDebito      Float   @default(0) @map("valor_abatido_debito")
  // Quanto da compensação foi descartada por ultrapassar o cap acumulado
  // da injeção da usina (créditos legados não remuneráveis ao investidor).
  // > 0 dispara alerta na UI.
  kwhCreditoLegadoAbatido Float   @default(0) @map("kwh_credito_legado_abatido")
  valorLiquido            Float   @map("valor_liquido")
  motivoAjuste            String? @map("motivo_ajuste")

  // Valor EFETIVAMENTE transferido ao investidor (pode diferir de valorLiquido
  // em caso de pagamento manual fora do fluxo normal). Quando preenchido e
  // diferente de valorLiquido, a diferença gera InvestorDebit automaticamente.
  valorRealPago       Float?  @map("valor_real_pago")
  motivoValorRealPago String? @map("motivo_valor_real_pago")

  // AGUARDANDO_COMPENSACAO | AGUARDANDO_PAGAMENTO | DISPONIVEL | PAGO | EM_COBRANCA_JUDICIAL
  status String @default("AGUARDANDO_COMPENSACAO")

  // Rastreabilidade — de onde veio cada transição
  consumerBillId        String? @map("consumer_bill_id")
  consumerUnitBillingId String? @map("consumer_unit_billing_id")
  investorSettlementId  String? @map("investor_settlement_id")

  // Fatura da UC GERADORA cujo ciclo de leitura dispachou os créditos que
  // originaram este payable. (anoReferencia, mesReferencia) desta fatura é o
  // "mês de geração" e a competência correta do relatório do investidor.
  // Pode ser null pra payables antigos antes do backfill.
  originatedByPlantBillId String? @map("originated_by_plant_bill_id")

  // Marcos temporais
  compensadoEm      DateTime? @map("compensado_em")
  pagoClienteEm     DateTime? @map("pago_cliente_em")
  disponibilizadoEm DateTime? @map("disponibilizado_em")
  pagoInvestidorEm  DateTime? @map("pago_investidor_em")

  // Cobrança judicial (fora do fluxo normal)
  cobrancaJudicialEm   DateTime? @map("cobranca_judicial_em")
  cobrancaJudicialNota String?   @map("cobranca_judicial_nota")

  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Saldo carregado de payable de mês anterior (operador editou o kWh do mês N
  // e o restante virou nova linha no resumo do mês N+1, e assim por diante).
  // Sempre aponta para o payable ORIGINAL (não pra cadeia intermediária), pra
  // preservar o rótulo "saldo de [mês de origem]" através de múltiplos saltos.
  carriedFromPayableId String? @map("carried_from_payable_id")

  investor              Investor                   @relation(fields: [investorId], references: [id], onDelete: Cascade)
  plant                 Plant                      @relation(fields: [plantId], references: [id])
  consumerUnit          ConsumerUnit               @relation(fields: [consumerUnitId], references: [id])
  consumerBill          ConsumerBill?              @relation("PayablesFromConsumerBill", fields: [consumerBillId], references: [id])
  originatedByPlantBill ConsumerBill?              @relation("PayablesOriginatedByPlantBill", fields: [originatedByPlantBillId], references: [id])
  consumerUnitBilling   ConsumerUnitBilling?       @relation(fields: [consumerUnitBillingId], references: [id])
  investorSettlement    InvestorSettlement?        @relation(fields: [investorSettlementId], references: [id])
  rateioVersion         RateioVersion?             @relation(fields: [rateioVersionId], references: [id])
  debitApplications     InvestorDebitApplication[]
  debitosOriginados     InvestorDebit[]            @relation("PayableOrigemDebito")
  carriedFromPayable    InvestorPayable?           @relation("PayableSaldoCarregado", fields: [carriedFromPayableId], references: [id])
  saldosCarregados      InvestorPayable[]          @relation("PayableSaldoCarregado")

  // Permite múltiplas linhas no mesmo (inv, uc, ano, mes, parcela) desde que
  // venham de origens diferentes — natural (carriedFromPayableId NULL) + uma
  // saldo line por origem distinta.
  @@unique([investorId, consumerUnitId, anoReferencia, mesReferencia, parcelaIndex, carriedFromPayableId])
  @@index([status, anoReferencia, mesReferencia])
  @@index([investorId, status])
  @@index([plantId, anoReferencia, mesReferencia])
  @@index([originatedByPlantBillId])
  @@index([carriedFromPayableId])
  @@map("investor_payables")
}

// Débito do investidor com a empresa — tipicamente pagamento a maior
// que foi feito no passado e precisa ser amortizado nos próximos repasses.
// valorRestante começa = valorOriginal e é decrementado a cada aplicação
// em uma InvestorPayable até chegar a 0 (status = QUITADO).
model InvestorDebit {
  id              String    @id @default(cuid())
  investorId      String    @map("investor_id")
  valorOriginal   Float     @map("valor_original")
  valorRestante   Float     @map("valor_restante")
  motivo          String?
  // Payable que originou o débito (quando foi criado automaticamente por
  // markInvestorPayableAsPaid ao detectar valorRealPago > valorLiquido).
  // NULL = débito registrado manualmente.
  payableOrigemId String?   @map("payable_origem_id")
  // ABERTO | QUITADO | CANCELADO
  status          String    @default("ABERTO")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  quitadoEm       DateTime? @map("quitado_em")
  canceladoEm     DateTime? @map("cancelado_em")
  criadoPorUserId String?   @map("criado_por_user_id")

  investor      Investor                   @relation(fields: [investorId], references: [id], onDelete: Cascade)
  applications  InvestorDebitApplication[]
  payableOrigem InvestorPayable?           @relation("PayableOrigemDebito", fields: [payableOrigemId], references: [id])

  @@index([investorId, status])
  @@index([payableOrigemId])
  @@map("investor_debits")
}

// Registro de uma aplicação parcial (ou total) de um débito em uma payable.
// Mantém auditoria: quanto foi abatido, quando, de qual débito, em qual payable.
// Cancelamento do débito apaga as applications e restaura o valorLiquido das payables.
model InvestorDebitApplication {
  id           String   @id @default(cuid())
  debitId      String   @map("debit_id")
  payableId    String   @map("payable_id")
  valorAbatido Float    @map("valor_abatido")
  aplicadoEm   DateTime @default(now()) @map("aplicado_em")

  debit   InvestorDebit   @relation(fields: [debitId], references: [id], onDelete: Cascade)
  payable InvestorPayable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@unique([debitId, payableId])
  @@index([payableId])
  @@map("investor_debit_applications")
}

// Fechamento mensal de pagamento ao investidor.
// Agrupa os InvestorPayable DISPONIVEL no momento da geração (podem ser de várias
// referências — ex.: parcela de janeiro que só foi paga pelo cliente em abril entra
// no fechamento de abril).
// Fluxo: DRAFT (job dia 20 cria) → PUBLISHED (Paulo confirma após revisar/ajustar).
model InvestorSettlement {
  id String @id @default(cuid())

  investorId    String @map("investor_id")
  anoFechamento Int    @map("ano_fechamento") // mês calendário em que o fechamento acontece (ex.: 2026/04)
  mesFechamento Int    @map("mes_fechamento")

  // DRAFT | PUBLISHED | CANCELED
  status String @default("DRAFT")

  // Snapshot dos totais (recalculado quando publica)
  totalKwh      Float @default(0) @map("total_kwh")
  totalBruto    Float @default(0) @map("total_bruto")
  totalAjuste   Float @default(0) @map("total_ajuste")
  totalLiquido  Float @default(0) @map("total_liquido")
  totalPayables Int   @default(0) @map("total_payables")

  // Linha extra do fechamento: gestão fixa mensal do contrato InvestorPlant
  gestaoFixaAplicada Float @default(0) @map("gestao_fixa_aplicada")

  // Ajustes manuais do operador no fechamento (soma livre)
  outrosAjustes Float   @default(0) @map("outros_ajustes")
  outrosNotas   String? @map("outros_notas")

  // Total que vai pro investidor (= totalLiquido − gestaoFixaAplicada + outrosAjustes)
  valorAPagar Float @default(0) @map("valor_a_pagar")

  // Marcos
  geradoEm        DateTime  @default(now()) @map("gerado_em")
  publicadoEm     DateTime? @map("publicado_em")
  pagoEm          DateTime? @map("pago_em")
  pagoComprovante String?   @map("pago_comprovante")

  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  investor Investor          @relation(fields: [investorId], references: [id], onDelete: Cascade)
  payables InvestorPayable[]

  @@unique([investorId, anoFechamento, mesFechamento])
  @@index([status, anoFechamento, mesFechamento])
  @@map("investor_settlements")
}

// ============================================================
// FECHAMENTO FINANCEIRO — config
// ============================================================
// Alíquota de imposto vigente a partir de um mês. O cálculo do fechamento
// busca a TaxRate cuja vigenciaInicio é <= primeiro dia do mês referente.
model TaxRate {
  id             String   @id @default(cuid())
  // Primeiro dia do mês a partir do qual a alíquota passa a valer.
  vigenciaInicio DateTime @map("vigencia_inicio")
  // Percentual sobre receita bruta (0..100). Ex.: 6.0 = 6%.
  percentual     Float
  observacao     String?
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  @@unique([vigenciaInicio])
  @@map("tax_rates")
}

// Catálogo de rubricas de custos fixos (Click Sign, Contador, Folha, etc.).
// Cada rubrica tem um valor padrão que é proposto a cada novo mês;
// o gestor confirma/edita o valor efetivo na entrada do mês.
model RecurringCost {
  id           String   @id @default(cuid())
  nome         String
  // Categoria livre (texto) — agrupa no relatório. Ex.: "Folha", "Software", "Infra".
  categoria    String?
  valorPadrao  Float    @default(0) @map("valor_padrao")
  ativo        Boolean  @default(true)
  ordem        Int      @default(0)
  observacao   String?
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  entries RecurringCostEntry[]

  @@unique([nome])
  @@index([ativo, ordem])
  @@map("recurring_costs")
}

// Valor efetivo de uma rubrica em um mês específico. Criado/atualizado quando
// o gestor confirma o valor durante o fechamento. Se não existir entry, o
// fechamento usa valorPadrao da RecurringCost.
model RecurringCostEntry {
  id                  String   @id @default(cuid())
  recurringCostId     String   @map("recurring_cost_id")
  ano                 Int
  mes                 Int
  valor               Float
  // Snapshot do valorPadrao no momento da confirmação (auditoria).
  valorPadraoNoMes    Float?   @map("valor_padrao_no_mes")
  confirmadoEm        DateTime @default(now()) @map("confirmado_em")
  confirmadoPorUserId String?  @map("confirmado_por_user_id")
  observacao          String?

  recurringCost RecurringCost @relation(fields: [recurringCostId], references: [id], onDelete: Cascade)

  @@unique([recurringCostId, ano, mes])
  @@index([ano, mes])
  @@map("recurring_cost_entries")
}
